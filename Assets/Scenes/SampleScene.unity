--- !u!114 &1328705242
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1328705236}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f6f1a951b676f1c43b9b12c5d03e5c5e, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::AudioGuideKeyPress
  audioSource: {fileID: 1328705243}
  subtitleText: "Anda kini sedang memandangi lukisan karya Basoeki Abdullah yang
    berjudul asli Flora Fauna Kekayaan Langka. \n\nLukisan cat minyak berukuran besar
    ini menggambarkan pesona bawah laut Indonesia yang dipenuhi terumbu karang warna-warni
    dan berbagai ikan yang hidup di dalamnya. Kehadiran seorang penyelam lokal yang
    menyentuh terumbu karang merah melambangkan kebanggaan dan kecintaan sang pelukis
    terhadap kekayaan alam Nusantara, sekaligus menjadi pesan mendalam bagi kita
    semua untuk selalu menjaga dan melestarikan ekosistem laut ini."
  subtitleUI: {fileID: 1694706750}
  tombolInteraksi: 113
  promptUI: {fileID: 1526662657}
