  m_Script: {fileID: 11500000, guid: f6f1a951b676f1c43b9b12c5d03e5c5e, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::AudioGuideKeyPress
  audioSource: {fileID: 24108053}
  subtitleText: "Anda kini sedang menatap The Starry Night atau Malam Berbintang,
    mahakarya pasca-impresionisme dari Vincent van Gogh. \n\nDilukis pada tahun seribu
    delapan ratus delapan puluh sembilan dari balik jendela kamar rumah sakit jiwa
    di Prancis, lukisan ini menampilkan pusaran langit malam biru yang dramatis,
    bintang-bintang kuning yang berpijar terang, dan pohon cemara yang menjulang
    bagai api hitam. Sapuan kuas Van Gogh yang tebal dan emosional mencerminkan gejolak
    jiwanya sekaligus keindahan luar biasa yang ia rasakan di tengah kegelapan."
  subtitleUI: {fileID: 2104430066}
  tombolInteraksi: 113
  promptUI: {fileID: 567461200}
