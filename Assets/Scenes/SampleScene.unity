  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f6f1a951b676f1c43b9b12c5d03e5c5e, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::AudioGuideKeyPress
  audioSource: {fileID: 1033137419}
  subtitleText: 'Anda kini sedang menatap Topeng Kematian Tutankhamun, simbol kekuasaan
    mutlak dari Mesir Kuno. Ditempa dari emas murni berkilau dan dihiasi batuan berharga,
    topeng ini menyelimuti wajah mumi sang raja untuk melindunginya dari kekuatan
    gelap di alam baka.


    Legenda kuno menyebutkan adanya kutukan bagi siapa
    saja yang berani mengusik tempat peristirahatan aslinya. Tapi jangan khawatir,
    replika digital di depan Anda ini sepenuhnya aman untuk diperiksa... atau benarkah
    demikian?'
  subtitleUI: {fileID: 448609413}
  tombolInteraksi: 113
  promptUI: {fileID: 2046541403}
