--- !u!114 &89247631
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 89247629}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Nama Artefak: Lukisan Mona Lisa\n\nKategori: Lukisan potret\n\nAsal/Periode:
    Italia, awal abad ke-16 (\xB11503\u20131506)\n\nDeskripsi: Lukisan karya Leonardo
    da Vinci yang terkenal dengan senyum misteriusnya.\n\nCatatan Edukatif: Salah
    satu karya seni paling terkenal dalam sejarah Renaisans."
