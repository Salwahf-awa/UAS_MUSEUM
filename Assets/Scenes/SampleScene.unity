  m_Script: {fileID: 11500000, guid: f6f1a951b676f1c43b9b12c5d03e5c5e, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::AudioGuideKeyPress
  audioSource: {fileID: 794743067}
  subtitleText: "Selamat datang di depan The Scream karya Edvard Munch, sebuah simbol
    ikonik dari kecemasan manusia modern. \n\nDiciptakan pada akhir abad kesembilan
    belas, lukisan beraliran ekspresionisme ini menggambarkan sosok figur dengan
    wajah penuh ketakutan di bawah langit senja yang berwarna merah darah. Munch
    terinspirasi dari pengalaman pribadinya saat berjalan di waktu senja, ketika
    ia tiba-tiba merasakan jeritan tak bertepi dari alam yang mencengkeram jiwanya."
  subtitleUI: {fileID: 554158886}
  tombolInteraksi: 113
  promptUI: {fileID: 1292875700}
