  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f6f1a951b676f1c43b9b12c5d03e5c5e, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::AudioGuideKeyPress
  audioSource: {fileID: 356876815}
  subtitleText: "Selamat datang di depan lukisan Ibuku, sebuah karya awal yang sangat
    personal dari maestro ekspresionis Indonesia, Affandi, pada tahun seribu sembilan
    ratus empat puluh satu. \n\nBerbeda dengan gaya khasnya yang penuh dengan plototan
    cat liar di kemudian hari, lukisan ini dibuat dengan teknik realisme yang sangat
    anggun mirip gaya renaisans Eropa. Penggambaran sosok ibunda yang sudah tua dalam
    pakaian sederhana ini mencerminkan penghormatan, kecintaan, serta kelembutan
    terdalam Affandi kepada sang ibu."
  subtitleUI: {fileID: 1917027349}
  tombolInteraksi: 113
  promptUI: {fileID: 1563994484}
