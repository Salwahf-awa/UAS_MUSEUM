--- !u!114 &1122259237
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1122259229}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f6f1a951b676f1c43b9b12c5d03e5c5e, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::AudioGuideKeyPress
  audioSource: {fileID: 1122259236}
  subtitleText: 'Anda sedang menatap Batu Rosetta, kunci pemecah sandi paling legendaris
    di dunia. Selama berabad-abad, rahasia makam para firaun terkunci rapat karena
    tidak ada satu pun manusia modern yang bisa membaca tulisan dinding mereka.


    Prasasti
    hitam inilah yang akhirnya memecahkan keheningan tersebut. Tiga bahasa terukir
    di permukaannya, bertindak sebagai jembatan waktu yang menghubungkan kita dengan
    bisikan sejarah masa lalu. Dekati batunya, dan dengarkan rahasia kuno yang mulai
    terungkap.'
  subtitleUI: {fileID: 1898798410}
  tombolInteraksi: 113
  promptUI: {fileID: 91193672}
