  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f6f1a951b676f1c43b9b12c5d03e5c5e, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::AudioGuideKeyPress
  audioSource: {fileID: 1894550100}
  subtitleText: "Di hadapan Anda adalah Penangkapan Pangeran Diponegoro, mahakarya
    legendaris dari pionir seni lukis modern Indonesia, Raden Saleh, yang dibuat
    pada tahun seribu delapan ratus lima puluh tujuh. \n\nLukisan dramatis ini merekam
    peristiwa sejarah penting saat Pangeran Diponegoro ditangkap oleh kolonial Belanda.
    Perhatikan ekspresi tegas dan penuh keberanian pada wajah sang pangeran, yang
    sengaja dilukis Raden Saleh untuk memancarkan semangat perlawanan dan harga diri
    bangsa yang tidak pernah tunduk pada penjajah."
  subtitleUI: {fileID: 2054628578}
  tombolInteraksi: 113
  promptUI: {fileID: 1728146606}
