  m_Script: {fileID: 11500000, guid: f6f1a951b676f1c43b9b12c5d03e5c5e, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::AudioGuideKeyPress
  audioSource: {fileID: 1482713933}
  subtitleText: Selamat datang di hadapan Monalisa, salah satu lukisan paling misterius
    dan terkenal di dunia karya Leonardo da Vinci. Dilukis pada abad keenam belas,
    karya ini memikat jutaan mata berkat senyuman enigmatis sang wanita yang tampak
    berubah-ubah tergantung dari mana Anda memandangnya. Da Vinci menggunakan teknik
    sfumato yang sangat halus untuk membaurkan bayangan pada sudut mata dan bibirnya,
    menciptakan ilusi hidup yang terus membingungkan para pengamat seni selama berabad-abad.
  subtitleUI: {fileID: 1825790815}
  tombolInteraksi: 113
  promptUI: {fileID: 1604299983}
